// Project level configuration for disabling IntelliSense/Suggestion. (Not for development environment, only for learning)

{
  // IntelliSense Disabled Settings
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.suggestOnTriggerCharacters": false,
  "editor.parameterHints.enabled": false,
  "editor.inlineSuggest.enabled": false,
  "editor.wordBasedSuggestions": "off",

  // Disable Auto Import Suggestions
  "js/ts.suggest.autoImports": false,

  // Zero Suggestions at All
  "editor.suggest.showKeywords": false,
  "editor.suggest.showSnippets": false
}
